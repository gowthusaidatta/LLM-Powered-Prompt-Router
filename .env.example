# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Your Groq API key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# If 1, app can run in offline fallback mode when GROQ_API_KEY is missing.
# Set to 0 for strict mode (fails fast without key).
OFFLINE_FALLBACK=1

CLASSIFIER_MODEL=llama-3.1-8b-instant
RESPONSE_MODEL=llama-3.3-70b-versatile
# Use a float between 0.0 and 1.0
CONFIDENCE_THRESHOLD=0.7
APP_PORT=8000
